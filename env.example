# --- Nouvelle base de données (Neon) ---
# Neon Dashboard → Connection Details → "Pooled connection"
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.eu-central-1.aws.neon.tech/europermis?sslmode=require

# --- Sessions ---
# Génère avec : openssl rand -base64 48
SESSION_SECRET=

# --- Divers ---
NODE_ENV=development

# ⚠️ Variables SUPPRIMÉES (ne plus utiliser, à retirer une fois la migration terminée) :
#   SUPABASE_URL, SUPABASE_PUBLISHABLE_KEY, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_PROJECT_ID
#   VITE_SUPABASE_URL, VITE_SUPABASE_PUBLISHABLE_KEY, VITE_SUPABASE_PROJECT_ID
#   SEED_SECRET
